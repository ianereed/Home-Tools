<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.home-tools.mount-nas</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/homeserver/Home-Tools/Mac-mini/scripts/mount-nas.sh</string>
  </array>

  <!-- Run at login (boot, since auto-login is on) AND every 5 min as a
       low-cost re-check that mount didn't drop. The script is idempotent. -->
  <key>RunAtLoad</key>
  <true/>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>StandardOutPath</key>
  <string>/Users/homeserver/Library/Logs/home-tools-mount-nas.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/homeserver/Library/Logs/home-tools-mount-nas-error.log</string>
</dict>
</plist>
