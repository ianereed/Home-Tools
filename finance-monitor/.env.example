# Ollama endpoint (no change needed if running locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# Slack tokens (from api.slack.com/apps → Finance Bot)
SLACK_APP_TOKEN=xapp-...    # Socket Mode App-Level Token
SLACK_BOT_TOKEN=xoxb-...    # Bot User OAuth Token

# Comma-separated Slack user IDs allowed to DM the bot. Leave empty to allow
# any workspace member (NOT RECOMMENDED — bot will log a warning at startup).
# To find your user ID: Slack profile → "..." menu → "Copy member ID".
ALLOWED_SLACK_USER_IDS=U12345678
