# ── Ollama (must be running locally) ─────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b
# Vision model for local-first image/PDF analysis. Pull with: ollama pull qwen2.5vl:7b
LOCAL_VISION_MODEL=qwen2.5vl:7b

# ── Google (Gmail + Calendar) ─────────────────────────────────────────────────
# OAuth2 client secrets downloaded from Google Cloud Console
GMAIL_CREDENTIALS_JSON=credentials/gmail_oauth.json
GMAIL_TOKEN_JSON=credentials/gmail_token.json
GCAL_TOKEN_JSON=credentials/gcal_token.json
# Primary calendar — read for context + dedup. The tool never writes here
# spontaneously; primary patches go through the proposal flow.
GCAL_PRIMARY_CALENDAR_ID=primary
# Weekend calendar — write target. New events land here. Additive merges
# to events already on weekend happen silently with a dashboard notice.
GCAL_WEEKEND_CALENDAR_ID=primary
# Legacy alias — accepted as fallback for GCAL_WEEKEND_CALENDAR_ID.
# GCAL_TARGET_CALENDAR_ID=...

# ── Slack ─────────────────────────────────────────────────────────────────────
# Reuse existing SLACK_BOT_TOKEN if already set
SLACK_BOT_TOKEN=xoxb-...
SLACK_MONITOR_CHANNELS=general,random          # comma-separated channel names
SLACK_DIGEST_USER_ID=U...                      # your Slack user ID (bot DMs this user)
SLACK_EVENT_LOG_CHANNEL=#event-log             # channel for per-event audit log (iOS-accessible)

# ── Discord ───────────────────────────────────────────────────────────────────
# Bot requires OAuth2 scopes: bot + Read Messages + Read Message History ONLY
DISCORD_BOT_TOKEN=...
DISCORD_MONITOR_CHANNELS=123456789,987654321   # channel IDs (right-click → Copy ID)

# ── macOS local DB paths ──────────────────────────────────────────────────────
# These defaults work on most Mac setups; override only if your paths differ
IMESSAGE_DB_PATH=~/Library/Messages/chat.db
WHATSAPP_DB_PATH=~/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/ChatStorage.sqlite

# Optional: when set, IMessageConnector reads this JSONL file instead of
# chat.db. Used on hosts (e.g. the headless Mac mini) that don't have iMessage
# signed in but receive a JSONL shipped over Tailscale SSH from a host that
# does. See event-aggregator/tools/README.md. Leave UNSET on the laptop so
# interactive runs continue to read chat.db directly.
# IMESSAGE_EXPORT_FILE=/Users/homeserver/Home-Tools/event-aggregator/cache/imessage.jsonl
# IMESSAGE_EXPORT_MAX_AGE_MIN=120

# ── Digest schedule ───────────────────────────────────────────────────────────
DIGEST_DAILY_HOUR=7    # local hour to send daily digest (0–23)
DIGEST_WEEKLY_DOW=0    # day of week for weekly digest (0=Mon, 6=Sun)

# ── Todoist (optional) ────────────────────────────────────────────────────────
# Enables extraction of action items, commitments, and follow-ups from messages.
# Get your API token from: todoist.com/app/settings/integrations/developer
# The target project is auto-created on first run if it doesn't exist.
TODOIST_API_TOKEN=your_token_here
TODOIST_PROJECT_NAME=automated todo aggregation   # project name to create/use
TODOIST_TODO_MIN_CONFIDENCE=0.65                  # drop todos below this score (0.0–1.0)

# ── Ollama context + keep_alive ──────────────────────────────────────────────
# Token ceilings per call. 16k is the safe-headroom default on the 24 GB mini
# (see plan B.6.2 for memory math). Don't go above this without verifying
# RAM headroom — qwen3:14b at 16k uses ~14 GB hot.
OLLAMA_NUM_CTX_TEXT=16384
OLLAMA_NUM_CTX_VISION=16384
# Keep the primary text model resident (-1 = forever); unload vision quickly
# after a swap-in finishes so primary can come back hot.
OLLAMA_KEEP_ALIVE_TEXT=-1
OLLAMA_KEEP_ALIVE_VISION=30s

# ── NAS / staging ────────────────────────────────────────────────────────────
# Files are always staged locally first, then copied to NAS, then purged locally.
NAS_ROOT=/Volumes/Share1
LOCAL_STAGING_DIR=~/Documents/event-aggregator-intake
IMAGE_CONFIDENCE_MIN=0.3                          # below this → file to Unsorted/
