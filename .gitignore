venv/
data/
screenshots/
*.log
*.db
__pycache__/
*.pyc
.DS_Store

# Sensitive — local only
medical-records/
add_recovery_tab.py
update_sheets.py
*.png

# Defense in depth: never commit any .env file (per-project .gitignores already
# cover the known ones; this catches future projects that forget to set theirs).
# .env.example / .env.sample / .env.template templates are NOT matched by these
# patterns and remain tracked.
.env
**/.env

# Transient runtime locks — never commit
*.lock

# Session journals — may contain raw command output / secrets
journal-*.md

# Finance monitor — sensitive data never committed
finance-monitor/.env
finance-monitor/data/
finance-monitor/intake/
finance-monitor/imported/
finance-monitor/state.json

# Event-aggregator runtime data — JSONL of iMessages, ships from laptop
event-aggregator/cache/*.jsonl

# nas-intake runtime state — local stability gate + dedup history; never commit
nas-intake/state.json
nas-intake/state.json.tmp
nas-intake/locks/

# Pyenv / uv venv dirs anywhere in the tree
.venv/

# gstack local artifacts: review logs, security reports, learnings, plan files.
# Stay local — never commit security findings to a public repo.
.gstack/
